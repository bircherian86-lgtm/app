{
  "name": "nova-optimizer",
  "private": true,
  "version": "1.0.4",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite --port 3252",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite --port 3252\" \"wait-on tcp:3252 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder",
    "dist": "npm run electron:build"
  },
  "build": {
    "appId": "com.nova.optimizer",
    "productName": "Nova Optimizer",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "systeminformation": "^5.31.5"
  }
}
